# Xi-agent hook template for the emoji display daemon.
#
# Append this to ~/.config/xi/config.toml (or merge with your existing hooks).
# Each hook writes one generic display-state transition to the daemon FIFO.
#
# Hook point → display state mapping:
#   pre_turn                 → waiting
#   on_first_thinking_token  → thinking
#   on_first_text_token      → responding
#   pre_tool                 → tool_<name>  (one entry per tool below)
#   on_done                  → done
#   on_idle                  → idle
#   on_error                 → error
#   on_compacting            → compacting
#   on_external_change       → external_change
#   on_status_update         → status_update
#
# Keep in sync with states.json — if you add/rename a tool there, add a
# matching [[hooks.pre_tool]] entry here.

[[hooks.pre_turn]]
bash = "echo '{\"state\":\"waiting\"}' >> /tmp/xi_display_fifo"

[[hooks.on_first_thinking_token]]
bash = "echo '{\"state\":\"thinking\"}' >> /tmp/xi_display_fifo"

[[hooks.on_first_text_token]]
bash = "echo '{\"state\":\"responding\"}' >> /tmp/xi_display_fifo"

[[hooks.on_done]]
bash = "echo '{\"state\":\"done\"}' >> /tmp/xi_display_fifo"

[[hooks.on_idle]]
bash = "echo '{\"state\":\"idle\"}' >> /tmp/xi_display_fifo"

[[hooks.on_error]]
bash = "echo '{\"state\":\"error\"}' >> /tmp/xi_display_fifo"

[[hooks.on_compacting]]
bash = "echo '{\"state\":\"compacting\"}' >> /tmp/xi_display_fifo"

[[hooks.on_external_change]]
bash = "echo '{\"state\":\"external_change\"}' >> /tmp/xi_display_fifo"

[[hooks.on_status_update]]
bash = "echo '{\"state\":\"status_update\"}' >> /tmp/xi_display_fifo"

# ── Tool hooks (one per tool; pre_tool fires when the agent starts executing) ──

[[hooks.pre_tool]]
include_tools = ["bash"]
bash = "echo '{\"state\":\"tool_bash\"}' >> /tmp/xi_display_fifo"

[[hooks.pre_tool]]
include_tools = ["exec"]
bash = "echo '{\"state\":\"tool_exec\"}' >> /tmp/xi_display_fifo"

[[hooks.pre_tool]]
include_tools = ["python"]
bash = "echo '{\"state\":\"tool_python\"}' >> /tmp/xi_display_fifo"

[[hooks.pre_tool]]
include_tools = ["read_file"]
bash = "echo '{\"state\":\"tool_read_file\"}' >> /tmp/xi_display_fifo"

[[hooks.pre_tool]]
include_tools = ["write_file"]
bash = "echo '{\"state\":\"tool_write_file\"}' >> /tmp/xi_display_fifo"

[[hooks.pre_tool]]
include_tools = ["edit_file"]
bash = "echo '{\"state\":\"tool_edit_file\"}' >> /tmp/xi_display_fifo"

[[hooks.pre_tool]]
include_tools = ["find_files"]
bash = "echo '{\"state\":\"tool_find_files\"}' >> /tmp/xi_display_fifo"

[[hooks.pre_tool]]
include_tools = ["ask_user"]
bash = "echo '{\"state\":\"tool_ask_user\"}' >> /tmp/xi_display_fifo"
